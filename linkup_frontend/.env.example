NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOCKET_URL=

# Local development:
# NEXT_PUBLIC_API_URL=http://localhost:3000
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Production (required in Vercel — do NOT use localhost):
# NEXT_PUBLIC_API_URL=https://api.thelinkupzone.com
# NEXT_PUBLIC_SOCKET_URL=https://api.thelinkupzone.com
# Realtime WebSockets run on Render/Railway/VPS — NOT on Vercel.
# NODE_ENV=production (set automatically on Vercel)

# Legacy production fallback (use until API custom domain is ready):
# NEXT_PUBLIC_API_URL=https://linkup-backend-oabq.onrender.com

# Canonical frontend: https://www.thelinkupzone.com
# Add thelinkupzone.com + www.thelinkupzone.com in Vercel Domains.
# Apex thelinkupzone.com redirects to www via next.config.ts.
