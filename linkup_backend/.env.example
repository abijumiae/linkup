DATABASE_URL=
JWT_SECRET=
FRONTEND_URL=
NODE_ENV=

# Local development example values:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
# JWT_SECRET="change_this_to_a_secure_secret"
# FRONTEND_URL="http://localhost:3001"
# NODE_ENV=development
# PORT=3000

# Production (Render) — custom domain
# FRONTEND_URL="https://www.thelinkupzone.com"
# PUBLIC_API_URL="https://api.thelinkupzone.com"
# CORS_ORIGINS="https://thelinkupzone.com,https://www.thelinkupzone.com,https://linkup-nu-ruby.vercel.app"
# NODE_ENV=production

# Media storage — local until Cloudinary is configured on Render
# STORAGE_PROVIDER=local
# STORAGE_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER="linkup"

# Legacy production URLs (keep until DNS fully migrated)
# FRONTEND_URL="https://linkup-nu-ruby.vercel.app"
# PUBLIC_API_URL="https://linkup-backend-oabq.onrender.com"

# Microsoft 365 / SMTP (admin@thelinkupzone.com)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Production SMTP example values:
# SMTP_HOST="smtp.office365.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="admin@thelinkupzone.com"
# SMTP_PASS="your-microsoft-365-app-password"
# MAIL_FROM="LinkUp <admin@thelinkupzone.com>"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Production Google callback:
# GOOGLE_CALLBACK_URL="https://api.thelinkupzone.com/auth/google/callback"
