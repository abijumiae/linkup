generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum AccountType {
  PERSONAL
  CREATOR
  BUSINESS
  STUDENT
  PROFESSIONAL
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  GROUP_JOIN
  MARKETPLACE_INQUIRY
  JOB_APPLICATION
  EVENT_JOIN
}

enum ReportTargetType {
  POST
  USER
  COMMENT
  GROUP
  MARKET
  JOB
  EVENT
}

enum ReportStatus {
  OPEN
  REVIEWING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum GroupRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum GroupLiveRole {
  LISTENER
  SPEAKER
  TEMP_ADMIN
}

enum GroupLiveRoomStatus {
  ACTIVE
  ENDED
}

model User {
  id           String      @id @default(cuid())
  name         String
  username     String      @unique
  email        String      @unique
  passwordHash String?
  provider     String      @default("local")
  googleId     String?     @unique
  role         Role        @default(USER)
  accountType  AccountType @default(PERSONAL)
  country      String?
  language     String?     @default("en")
  avatarUrl    String?
  coverUrl     String?
  bio          String?
  interests    String?
  skills       String?
  website      String?
  openToConnect String?
  isVerified   Boolean     @default(false)
  isOnboarded  Boolean     @default(true)
  isEmailVerified Boolean  @default(false)
  emailVerificationToken String?
  emailVerificationCode String?
  emailVerificationExpires DateTime?
  profileVisibility String @default("public")
  messagePermission String @default("everyone")
  showOnlineStatus  Boolean @default(true)
  showCountry       Boolean @default(true)
  showActivity      Boolean @default(true)
  online            Boolean   @default(false)
  lastSeenAt        DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  posts        Post[]
  likes        Like[]
  comments     Comment[]
  followers    Follow[]    @relation("UserFollowing")
  following    Follow[]    @relation("UserFollowers")
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationActor")
  sentMessages          Message[]        @relation("MessageSender")
  receivedMessages      Message[]        @relation("MessageReceiver")
  groupMessages         GroupMessage[]
  ownedGroups           Group[]             @relation("OwnedGroups")
  groupMembers          GroupMember[]
  marketplaceItems      MarketplaceItem[]
  postedJobs            Job[]             @relation("JobPoster")
  jobApplications       JobApplication[]  @relation("JobApplications")
  organizedEvents       Event[]           @relation("EventOrganizer")
  eventAttendances      EventAttendee[]
  moments               Moment[]
  watchVideos           WatchVideo[]   @relation("WatchVideoCreator")
  watchProgress         WatchProgress[]
  savedPosts            SavedPost[]
  blocksInitiated       Block[]        @relation("BlockInitiator")
  blocksReceived        Block[]        @relation("BlockTarget")
  reportsFiled          Report[]       @relation("ReportReporter")
  moderationLogs        ModerationLog[] @relation("ModerationActor")
  hostedGroupLiveRooms  GroupLiveRoom[] @relation("GroupLiveRoomHost")
  activeMicLiveRooms    GroupLiveRoom[] @relation("GroupLiveRoomActiveMic")
  groupLiveParticipations GroupLiveParticipant[]
  groupLiveTalkMessages   GroupLiveTalkMessage[]
  postReactions         PostReaction[]
  messageReactions      MessageReaction[]
}

model ModerationLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  notes      String?
  createdAt  DateTime @default(now())

  admin User @relation("ModerationActor", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@index([postId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlockInitiator", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockTarget", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Report {
  id         String           @id @default(cuid())
  reporterId String
  targetType ReportTargetType
  targetId   String
  reason     String
  details    String?
  status     ReportStatus     @default(OPEN)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  reporter User @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

model Post {
  id         String   @id @default(cuid())
  authorId   String
  groupId    String?
  content    String
  postType   String   @default("TEXT")
  visibility String   @default("PUBLIC")
  imageUrl   String?
  videoUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group    Group?    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  likes    Like[]
  reactions PostReaction[]
  comments Comment[]
  savedBy  SavedPost[]
  notifications Notification[]

  @@index([authorId])
  @@index([groupId])
  @@index([createdAt])
  @@index([groupId, createdAt(sort: Desc)])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String
  coverImage  String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner         User           @relation("OwnedGroups", fields: [ownerId], references: [id], onDelete: Cascade)
  members       GroupMember[]
  posts         Post[]
  messages      GroupMessage[]
  notifications Notification[]
  liveRooms     GroupLiveRoom[]

  @@index([ownerId])
}

model GroupLiveRoom {
  id                 String              @id @default(cuid())
  groupId            String
  hostId             String
  status             GroupLiveRoomStatus @default(ACTIVE)
  activeMicUserId    String?
  activeMicStartedAt DateTime?
  startedAt          DateTime            @default(now())
  endedAt            DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  group         Group                    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  host          User                     @relation("GroupLiveRoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  activeMicUser User?                    @relation("GroupLiveRoomActiveMic", fields: [activeMicUserId], references: [id], onDelete: SetNull)
  participants  GroupLiveParticipant[]
  messages      GroupLiveTalkMessage[]

  @@index([groupId, status])
  @@index([hostId])
  @@index([activeMicUserId])
}

model GroupLiveParticipant {
  id                  String         @id @default(cuid())
  roomId              String
  userId              String
  liveRole            GroupLiveRole  @default(LISTENER)
  isTempAdmin         Boolean        @default(false)
  tempAdminGrantedBy  String?
  tempAdminGrantedAt  DateTime?
  isMuted             Boolean        @default(true)
  handRaised          Boolean        @default(false)
  handRaisedAt        DateTime?
  joinedAt            DateTime       @default(now())
  leftAt              DateTime?

  room GroupLiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
  @@index([roomId, leftAt])
}

model GroupLiveTalkMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String?
  kind      String   @default("text")
  content   String
  createdAt DateTime @default(now())

  room GroupLiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([roomId, createdAt])
}

model GroupMember {
  id        String    @id @default(cuid())
  groupId   String
  userId    String
  role      GroupRole @default(MEMBER)
  createdAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([postId, createdAt])
  @@index([authorId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id                String           @id @default(cuid())
  type              NotificationType
  message           String
  recipientId       String
  actorId           String
  postId            String?
  groupId           String?
  marketplaceItemId String?
  jobId             String?
  eventId           String?
  read              Boolean          @default(false)
  createdAt         DateTime         @default(now())

  recipient       User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor           User             @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  post            Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  group           Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  marketplaceItem MarketplaceItem? @relation(fields: [marketplaceItemId], references: [id], onDelete: Cascade)
  job             Job?             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  event           Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@index([recipientId, read])
  @@index([recipientId, actorId, type, postId])
  @@index([recipientId, actorId, type, groupId])
  @@index([recipientId, actorId, type, marketplaceItemId])
  @@index([recipientId, actorId, type, jobId])
  @@index([recipientId, actorId, type, eventId])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String
  location    String
  startDate   DateTime
  endDate     DateTime?
  imageUrl    String?
  category    String?
  organizerId String
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organizer     User            @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  attendees     EventAttendee[]
  notifications Notification[]

  @@index([organizerId])
  @@index([status, startDate])
  @@index([category])
}

model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String   @default("GOING")
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

model Job {
  id           String   @id @default(cuid())
  title        String
  company      String
  description  String
  location     String
  jobType      String?
  salary       String?
  requirements String?
  contactEmail String?
  posterId     String
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  poster        User             @relation("JobPoster", fields: [posterId], references: [id], onDelete: Cascade)
  applications  JobApplication[]
  notifications Notification[]

  @@index([posterId])
  @@index([status, createdAt])
}

model JobApplication {
  id          String   @id @default(cuid())
  jobId       String
  applicantId String
  coverLetter String?
  resumeUrl   String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant User @relation("JobApplications", fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([jobId, applicantId])
  @@index([applicantId])
}

model MarketplaceItem {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  category    String
  condition   String?
  location    String?
  imageUrl    String?
  sellerId    String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller        User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([sellerId])
  @@index([status, createdAt])
  @@index([category])
}

model Message {
  id         String   @id @default(cuid())
  type       String   @default("text")
  content    String   @default("")
  mediaUrl   String?
  mediaType  String?
  duration   Int?
  senderId   String
  receiverId String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  reactions MessageReaction[]

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, read])
}

model PostReaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  emoji     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, emoji])
  @@index([postId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  userId    String
  messageId String
  emoji     String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId, emoji])
  @@index([messageId])
}

model GroupMessage {
  id        String   @id @default(cuid())
  content   String
  groupId   String
  senderId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@index([senderId])
}

model Moment {
  id          String   @id @default(cuid())
  userId      String
  content     String?
  mediaUrl    String?
  mediaType   String?
  background  String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model WatchVideo {
  id           String   @id @default(cuid())
  title        String
  description  String?
  videoUrl     String
  thumbnailUrl String?
  category     String?
  type         String?
  duration     Int?
  creatorId    String?
  isPublished  Boolean  @default(true)
  isPremium    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator  User?           @relation("WatchVideoCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  progress WatchProgress[]

  @@index([isPublished, createdAt])
  @@index([category])
  @@index([type])
}

model WatchProgress {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  video WatchVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId, updatedAt])
}
